{
  "name": "agent-native-monorepo",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "test:eval": "turbo test:eval",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "prettier": "^3.8.2",
    "turbo": "^2.5.0"
  },
  "resolutions": {
    "@grpc/grpc-js": "^1.14.4",
    "form-data": "^4.0.6",
    "langsmith": "^0.6.0",
    "multer": "^2.2.0",
    "protobufjs": "^7.6.5",
    "shell-quote": "^1.8.4",
    "vite-node/vite": "^7.3.6",
    "vitest/vite": "^7.3.6"
  }
}
